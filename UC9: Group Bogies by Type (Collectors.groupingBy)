import java.util.*;
import java.util.stream.Collectors;

// Base Bogie Class
abstract class Bogie {
    String bogieId;

    public Bogie(String bogieId) {
        this.bogieId = bogieId;
    }

    public abstract String getType();
    public abstract void display();
}

// Passenger Bogie
class PassengerBogie extends Bogie {
    String type;
    int capacity;

    public PassengerBogie(String bogieId, String type, int capacity) {
        super(bogieId);
        this.type = type;
        this.capacity = capacity;
    }

    public int getCapacity() {
        return capacity;
    }

    @Override
    public String getType() {
        return type;
    }

    @Override
    public void display() {
        System.out.println("Bogie ID: " + bogieId +
                ", Type: " + type +
                ", Capacity: " + capacity);
    }
}

// Main Class
public class UseCase9GroupBogies {
    public static void main(String[] args) {

        // Reuse list (same as UC7/UC8 style)
        List<Bogie> bogies = new ArrayList<>();

        bogies.add(new PassengerBogie("B1", "Sleeper", 72));
        bogies.add(new PassengerBogie("B2", "AC Chair", 60));
        bogies.add(new PassengerBogie("B3", "First Class", 40));
        bogies.add(new PassengerBogie("B4", "Sleeper", 80));
        bogies.add(new PassengerBogie("B5", "AC Chair", 70));

        System.out.println("=== Original Bogie List ===");
        bogies.forEach(b -> b.display());

        // Core Logic: groupingBy
        Map<String, List<Bogie>> groupedBogies =
                bogies.stream()
                      .collect(Collectors.groupingBy(b -> b.getType()));

        // Display grouped result
        System.out.println("\n=== Grouped Bogies by Type ===");

        for (Map.Entry<String, List<Bogie>> entry : groupedBogies.entrySet()) {
            System.out.println("\nType: " + entry.getKey());

            for (Bogie b : entry.getValue()) {
                b.display();
            }
        }

        // Validate original list unchanged
        System.out.println("\nOriginal list size: " + bogies.size());
        System.out.println("Number of groups: " + groupedBogies.size());
    }
}
